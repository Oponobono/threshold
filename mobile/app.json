{
  "expo": {
    "name": "Threshold",
    "slug": "threshold",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/images/android/play_store_512.png",
    "scheme": "threshold",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.oponobono.threshold",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./src/images/android/res/mipmap-xxxhdpi/threshold_foreground.png",
        "backgroundImage": "./src/images/android/res/mipmap-xxxhdpi/threshold_background.png",
        "monochromeImage": "./src/images/android/res/mipmap-xxxhdpi/threshold_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Threshold necesita acceso para escanear tus apuntes con precisión."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7cf9853-fa63-4fa1-9beb-e7da96cd4066"
      }
    }
  }
}
